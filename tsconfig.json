{
  "compilerOptions": {
    "lib": ["esnext"],
    "removeComments": false,
    "composite": false,
    "declaration": true,
    "strictNullChecks": false,
    "esModuleInterop": true,
    "sourceMap": false,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "preserveWatchOutput": true,
    "skipLibCheck": true,
    "strict": true,
    "outDir": "dist"
  },
  "include": ["src/**/*.ts"]
}
