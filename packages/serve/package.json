{
  "name": "@exlite/serve",
  "version": "0.0.1",
  "description": "Serve static websites (SPA's) using @exlite/serve",
  "private": true,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsup src/index.ts --format cjs,esm --dts --clean",
    "format": "prettier --write \"./src/**/*.{ts,js}\"",
    "lint": "eslint \"./src/**/*.{ts,js}\" --fix",
    "clean": "rimraf dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aashishpanchal/exlite.git"
  },
  "author": "Aashish Panchal <aipanchal51@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "express": "^4.21.0"
  },
  "dependencies": {
    "path-to-regexp": "^8.2.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.9",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2"
  },
  "keywords": [
    "exlite",
    "express",
    "@exlite/serve",
    "exlite-serve",
    "@nestjs/serve-static"
  ],
  "homepage": "https://github.com/aashishpanchal/exlite#readme"
}