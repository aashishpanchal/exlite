{
  "name": "exlite",
  "version": "0.1.1",
  "description": "Exlite is a lightweight utility library for express.js",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16.20.1"
  },
  "scripts": {
    "lint": "eslint --fix \"./src/**/*.ts\"",
    "format": "prettier --write \"**/*.{ts,js}\"",
    "build": "rimraf dist && tsup src/index.ts --format cjs,esm --dts --clean"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aashishpanchal/exlite.git"
  },
  "author": "Aashish Panchal <aipanchal51@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "express": "^4.21.0",
    "tsyringe": "^4.8.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-define-config": "^2.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "~5.5.4"
  },
  "keywords": [
    "express",
    "exlite",
    "helper",
    "tsyringe",
    "http-status",
    "http-errors"
  ],
  "homepage": "https://github.com/aashishpanchal/exlite#readme"
}